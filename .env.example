# Required — from https://my.telegram.org/apps
TG_API_ID=123456
TG_API_HASH=your_api_hash_here

# Required — generated by running `python login.py` locally once
TG_SESSION_STRING=paste_the_long_string_from_login.py_here

# Optional
TG_HELLO_MESSAGE=Hey! 👋 Thanks for reaching out — this is an automated first-time hello. I'll get back to you personally as soon as I can.
TG_SKIP_IF_YOU_MESSAGED_FIRST=true
TG_IGNORE_BOTS=true
TG_IGNORE_CONTACTS=true
